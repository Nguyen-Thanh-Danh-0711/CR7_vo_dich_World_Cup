<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400.0" prefWidth="600.0" spacing="15.0"
      style="-fx-background-color: #F9FAFB;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.shopcloud.superapp.controller.BuyerSpaceController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="200.0" spacing="10.0">
         <children>
            <TextField fx:id="searchField"
                       promptText="Tìm kiếm sản phẩm, thương hiệu..."
                       style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-padding: 8 15 8 15;"
                       HBox.hgrow="ALWAYS" />
            <Button fx:id="btnSearch"
                    mnemonicParsing="false"
                    onAction="#handleSearch"
                    style="-fx-background-color: #1E3A8A; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20 8 20; -fx-font-weight: bold; -fx-cursor: hand;"
                    text="Tìm kiếm" />
         </children>
      </HBox>

      <ScrollPane fx:id="productScrollPane"
                  fitToWidth="true"
                  hbarPolicy="NEVER"
                  prefHeight="200.0"
                  prefWidth="200.0"
                  style="-fx-background-color: transparent; -fx-background: transparent;"
                  VBox.vgrow="ALWAYS">
         <content>
            <TilePane fx:id="productGrid"
                      hgap="20.0"
                      prefHeight="200.0"
                      prefWidth="200.0"
                      vgap="20.0">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </TilePane>
         </content>
      </ScrollPane>
   </children>
</VBox>
