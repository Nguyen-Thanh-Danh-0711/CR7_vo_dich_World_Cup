<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>

<BorderPane prefHeight="768.0" prefWidth="1024.0" style="-fx-background-color: #F9FAFB;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.shopcloud.superapp.controller.AdminSpaceController">
   <top>
      <!-- Admin Header Banner -->
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #1F2937; -fx-padding: 0 25 0 25;" BorderPane.alignment="CENTER">
         <children>
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="⚙️ HỆ THỐNG QUẢN TRỊ ADMIN — SHOPCLOUD WORKSPACE" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="adminUserLabel" style="-fx-text-fill: #9CA3AF; -fx-font-weight: bold;" text="Admin: admin_ops" />
         </children>
      </HBox>
   </top>

   <center>
      <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent; -fx-fit-to-width: true; -fx-fit-to-height: true;" BorderPane.alignment="CENTER">
         <content>
            <VBox spacing="25.0" style="-fx-background-color: #F9FAFB; -fx-padding: 25;">
               <children>

                  <!-- 1. DASHBOARD STAT CARDS — RESPONSIVE HBOX (FULL WIDTH) -->
                  <HBox alignment="CENTER" maxWidth="1.7976931348623157E308" spacing="20.0" VBox.vgrow="NEVER">
                     <children>
                        <!-- Card 1: Tổng đơn hàng -->
                        <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" prefHeight="110.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                           <effect>
                              <DropShadow blurType="GAUSSIAN" color="#0000000d" offsetY="4.0" radius="10.0" />
                           </effect>
                           <children>
                              <VBox alignment="CENTER_LEFT" spacing="6.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12px; -fx-font-weight: bold;" text="TỔNG ĐƠN HÀNG HỆ THỐNG" />
                                    <Label fx:id="totalOrdersLabel" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #1F2937;" text="1,542" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <!-- Card 2: Cửa hàng hoạt động -->
                        <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" prefHeight="110.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                           <effect>
                              <DropShadow blurType="GAUSSIAN" color="#0000000d" offsetY="4.0" radius="10.0" />
                           </effect>
                           <children>
                              <VBox alignment="CENTER_LEFT" spacing="6.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12px; -fx-font-weight: bold;" text="CỬA HÀNG HOẠT ĐỘNG" />
                                    <Label fx:id="activeShopsLabel" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #1F2937;" text="89" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <!-- Card 3: Báo cáo vi phạm chưa xử lý -->
                        <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" prefHeight="110.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #FEE2E2; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                           <effect>
                              <DropShadow blurType="GAUSSIAN" color="#0000000d" offsetY="4.0" radius="10.0" />
                           </effect>
                           <children>
                              <VBox alignment="CENTER_LEFT" spacing="6.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label style="-fx-text-fill: #DC2626; -fx-font-size: 12px; -fx-font-weight: bold;" text="BÁO CÁO VI PHẠM CHỜ XỬ LÝ" />
                                    <Label fx:id="pendingReportsLabel" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #DC2626;" text="2" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </HBox>

                  <!-- 2. SECTION KÍCH HOẠT FLASH SALE -->
                  <HBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-padding: 20;" VBox.vgrow="NEVER">
                     <effect>
                        <DropShadow blurType="GAUSSIAN" color="#00000008" offsetY="4.0" radius="10.0" />
                     </effect>
                     <children>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-text-fill: #EF4444; -fx-font-size: 12px; -fx-font-weight: bold;" text="🔥 CHIẾN DỊCH KHẨN CẤP" />
                              <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Kích Hoạt Flash Sale Toàn Hệ Thống" />
                              <Label style="-fx-text-fill: #6B7280; -fx-font-size: 13px;" text="Gửi tín hiệu kích hoạt đồng loạt sự kiện flash sale xuống các dịch vụ backend thông qua API đóng gói và đồng bộ Redis." wrapText="true" />
                           </children>
                        </VBox>
                        <Button fx:id="btnTriggerFlashSale" mnemonicParsing="false" onAction="#handleKichHoatFlashSale" style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 24; -fx-background-radius: 8; -fx-cursor: hand;" text="KÍCH HOẠT FLASH SALE">
                           <effect>
                              <DropShadow radius="10.0">
                                 <color>
                                    <Color red="0.8627451062202454" green="0.14901961386203766" blue="0.14901961386203766" opacity="0.3" />
                                 </color>
                              </DropShadow>
                           </effect>
                        </Button>
                     </children>
                  </HBox>

                  <!-- 3. TAB MANAGEMENT CORE (TAB USERS, SHOPS, PRODUCTS BY SHOP, REPORT CENTER) -->
                  <TabPane fx:id="mainTabPane" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-padding: 15;" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                     <effect>
                        <DropShadow blurType="GAUSSIAN" color="#00000008" offsetY="4.0" radius="10.0" />
                     </effect>
                     <tabs>

                        <!-- TAB A: QUẢN LÝ NGƯỜI DÙNG -->
                        <Tab text="👥 Quản Lý Người Dùng">
                           <content>
                              <VBox spacing="15.0" style="-fx-padding: 15 5 5 5;">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                                       <children>
                                          <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Tìm kiếm người dùng:" />
                                          <TextField fx:id="userSearchField" prefWidth="250.0" promptText="Tìm theo Username hoặc Email..." style="-fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6;" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Button fx:id="btnToggleBanUser" mnemonicParsing="false" onAction="#handleToggleBanUser" style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;" text="🔒 Khóa / Mở Khóa Tài Khoản" />
                                          <Button fx:id="btnSendUserWarning" mnemonicParsing="false" onAction="#handleSendUserWarning" style="-fx-background-color: #D97706; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;" text="⚠️ Gửi Cảnh Báo" />
                                       </children>
                                    </HBox>

                                    <TableView fx:id="userTableView" minHeight="300.0" style="-fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                                       <columns>
                                          <TableColumn fx:id="colUserId" prefWidth="100.0" text="Mã ND" />
                                          <TableColumn fx:id="colUsername" prefWidth="180.0" text="Tên Người Dùng" />
                                          <TableColumn fx:id="colUserEmail" prefWidth="250.0" text="Email" />
                                          <TableColumn fx:id="colUserRole" prefWidth="130.0" text="Vai Trò" />
                                          <TableColumn fx:id="colUserStatus" prefWidth="150.0" text="Trạng Thái" />
                                       </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>
                                 </children>
                              </VBox>
                           </content>
                        </Tab>

                        <!-- TAB B: QUẢN LÝ SHOP -->
                        <Tab text="🏪 Quản Lý Shop">
                           <content>
                              <VBox spacing="15.0" style="-fx-padding: 15 5 5 5;">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                                       <children>
                                          <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Tìm kiếm Shop:" />
                                          <TextField fx:id="shopSearchField" prefWidth="250.0" promptText="Tìm theo Mã Shop hoặc Tên Shop..." style="-fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6;" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Button fx:id="btnToggleBanShop" mnemonicParsing="false" onAction="#handleToggleBanShop" style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;" text="🔒 Khóa / Mở Khóa Shop" />
                                          <Button fx:id="btnSendShopWarning" mnemonicParsing="false" onAction="#handleSendShopWarning" style="-fx-background-color: #D97706; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;" text="⚠️ Gửi Cảnh Báo Shop" />
                                       </children>
                                    </HBox>

                                    <TableView fx:id="shopTableView" minHeight="300.0" style="-fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                                       <columns>
                                          <TableColumn fx:id="colShopId" prefWidth="100.0" text="Mã Shop" />
                                          <TableColumn fx:id="colShopName" prefWidth="200.0" text="Tên Shop" />
                                          <TableColumn fx:id="colShopOwner" prefWidth="180.0" text="Chủ Sở Hữu" />
                                          <TableColumn fx:id="colShopJoinedDate" prefWidth="130.0" text="Ngày Tham Gia" />
                                          <TableColumn fx:id="colShopTotalProducts" prefWidth="120.0" text="Tổng Sản Phẩm" />
                                          <TableColumn fx:id="colShopStatus" prefWidth="140.0" text="Trạng Thái" />
                                       </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>
                                 </children>
                              </VBox>
                           </content>
                        </Tab>

                        <!-- TAB C: QUẢN LÝ SẢN PHẨM THEO SHOP -->
                        <Tab text="📦 Quản Lý Sản Phẩm Theo Shop">
                           <content>
                              <VBox spacing="15.0" style="-fx-padding: 15 5 5 5;">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                                       <children>
                                          <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Chọn Cửa Hàng / Shop:" />
                                          <ComboBox fx:id="shopSelectComboBox" prefWidth="280.0" promptText="-- Chọn Shop để xem sản phẩm --" style="-fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6;" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Button fx:id="btnDeleteProductViolation" mnemonicParsing="false" onAction="#handleDeleteProductViolation" style="-fx-background-color: #991B1B; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;" text="🗑️ Xóa Sản Phẩm Vi Phạm" />
                                          <Button fx:id="btnSendProductWarning" mnemonicParsing="false" onAction="#handleSendProductWarning" style="-fx-background-color: #D97706; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;" text="⚠️ Cảnh Báo Vi Phạm" />
                                       </children>
                                    </HBox>

                                    <TableView fx:id="productTableView" minHeight="300.0" style="-fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                                       <columns>
                                          <TableColumn fx:id="colProdId" prefWidth="90.0" text="Mã SP" />
                                          <TableColumn fx:id="colProdName" prefWidth="220.0" text="Tên Sản Phẩm" />
                                          <TableColumn fx:id="colProdPrice" prefWidth="130.0" text="Đơn Giá" />
                                          <TableColumn fx:id="colProdStock" prefWidth="100.0" text="Tồn Kho" />
                                          <TableColumn fx:id="colProdSold" prefWidth="100.0" text="Lượt Bán" />
                                          <TableColumn fx:id="colProdShopName" prefWidth="180.0" text="Thuộc Shop" />
                                          <TableColumn fx:id="colProdStatus" prefWidth="130.0" text="Trạng Thái Duyệt" />
                                       </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>
                                 </children>
                              </VBox>
                           </content>
                        </Tab>

                        <!-- TAB D: TRUNG TÂM BÁO CÁO VI PHẠM (INTEGRATED REPORT VIEW) -->
                        <Tab text="🚨 Trung Tâm Báo Cáo Vi Phạm">
                           <content>
                              <VBox fx:id="reportContainer" spacing="10.0" style="-fx-padding: 10 0 0 0;" VBox.vgrow="ALWAYS" />
                           </content>
                        </Tab>

                     </tabs>
                  </TabPane>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
