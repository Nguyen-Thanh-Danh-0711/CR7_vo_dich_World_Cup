<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="540.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #E5E7EB; -fx-border-width: 1;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.shopcloud.superapp.controller.AdminWarningModalController">
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
   <children>
      <!-- Title Bar -->
      <VBox spacing="6.0">
         <children>
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="🚨 GỬI CẢNH BÁO VI PHẠM (WARNING NOTICE)" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #6B7280;" text="Gửi thông báo cảnh báo trực tiếp vào Hộp thư của đối tượng bị báo cáo." />
         </children>
      </VBox>

      <!-- Target Info Card -->
      <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: #FEF3C7; -fx-background-radius: 8; -fx-padding: 12; -fx-border-color: #F59E0B; -fx-border-radius: 8;">
         <children>
            <Label style="-fx-font-weight: bold; -fx-text-fill: #92400E;" text="Đối tượng bị cảnh báo:" />
            <Label fx:id="targetInfoLabel" style="-fx-font-weight: bold; -fx-text-fill: #B45309; -fx-font-size: 14px;" text="[Mã ID - Tên đối tượng]" />
         </children>
      </HBox>

      <!-- Form Inputs -->
      <VBox spacing="14.0">
         <children>
            <VBox spacing="6.0">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Tiêu đề cảnh báo *" />
                  <TextField fx:id="titleField" promptText="Ví dụ: Cảnh báo vi phạm bản quyền thương hiệu CR7" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6;" />
               </children>
            </VBox>

            <VBox spacing="6.0">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Nội dung chi tiết vi phạm *" />
                  <TextArea fx:id="contentArea" prefHeight="110.0" promptText="Nhập nội dung giải thích chi tiết lý do cảnh báo và các quy định bị vi phạm..." style="-fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6;" wrapText="true" />
               </children>
            </VBox>

            <VBox spacing="6.0">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Thời hạn khắc phục (Deadline) *" />
                  <ComboBox fx:id="deadlineComboBox" maxWidth="1.7976931348623157E308" style="-fx-padding: 6; -fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6;" />
               </children>
            </VBox>
         </children>
      </VBox>

      <!-- Buttons Action -->
      <HBox alignment="CENTER_RIGHT" spacing="12.0">
         <children>
            <Button fx:id="btnCancelWarning" mnemonicParsing="false" onAction="#handleCancel" style="-fx-background-color: #F3F4F6; -fx-text-fill: #374151; -fx-font-weight: bold; -fx-padding: 9 20; -fx-background-radius: 6; -fx-cursor: hand;" text="Hủy bỏ" />
            <Button fx:id="btnConfirmSendWarning" mnemonicParsing="false" onAction="#handleSendWarning" style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 20; -fx-background-radius: 6; -fx-cursor: hand;" text="Gửi Cảnh Báo" />
         </children>
      </HBox>
   </children>
</VBox>
