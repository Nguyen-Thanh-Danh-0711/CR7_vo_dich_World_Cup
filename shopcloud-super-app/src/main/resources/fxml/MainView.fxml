<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0" prefWidth="1200.0" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.shopcloud.superapp.controller.MainController">

    <left>
        <VBox prefHeight="720.0" prefWidth="272.0" spacing="20" styleClass="sidebar">

            <padding>
                <Insets bottom="25" left="20" right="20" top="35" />
            </padding>

            <VBox alignment="CENTER" spacing="4" styleClass="brand-box">
                <Label styleClass="logo" text="☁ SHOP CLOUD" textFill="#1e3a8a">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font></Label>
                <Label styleClass="logo-subtitle" text="Workspace Portal">
               <font>
                  <Font size="14.0" />
               </font></Label>
            </VBox>

            <Button fx:id="btnBuyerSpace" maxWidth="Infinity" onAction="#loadBuyerSpace" style="-fx-background-color: #1E3A8A; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20 8 20; -fx-font-weight: bold;" styleClass="menu-button, menu-button-buyer" text="🛒   Không gian Người Mua">
                <effect>
                    <DropShadow color="#2563EB1A" offsetY="4" radius="15" />
                </effect>
            </Button>

            <Button fx:id="btnSellerSpace" maxWidth="Infinity" onAction="#loadSellerSpace" style="-fx-background-color: #1E3A8A; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20 8 20; -fx-font-weight: bold;" styleClass="menu-button, menu-button-seller" text="🏪   Kênh Người Bán">
                <effect>
                    <DropShadow color="#0596691A" offsetY="4" radius="15" />
                </effect>
            </Button>

            <Button fx:id="btnAdminSpace" maxWidth="Infinity" onAction="#loadAdminSpace" style="-fx-background-color: #1E3A8A; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20 8 20; -fx-font-weight: bold;" styleClass="menu-button, menu-button-admin" text="⚙   Quản Trị Admin">
                <effect>
                    <DropShadow color="#1E3A8A33" offsetY="4" radius="15" />
                </effect>
            </Button>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content" />
    </center>

</BorderPane>
