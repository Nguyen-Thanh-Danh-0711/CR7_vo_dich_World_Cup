<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #F4F6F9;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.java.com.shopcloud.superapp.controller.LoginController">
   <children>
      <HBox StackPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="450.0" spacing="20.0" style="-fx-background-color: linear-gradient(to bottom right, #1E3A8A, #2563EB);" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView fitHeight="100.0" fitWidth="250.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@assets/logo.png" />
                     </image>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </ImageView>
                  <Label alignment="CENTER" text="Chạm đám mây, chọn mua sắm" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            
            <AnchorPane prefHeight="200.0" prefWidth="550.0" style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS">
               <children>
                  <VBox layoutX="436.0" layoutY="208.0" prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 40;" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="50.0">
                     <effect>
                        <DropShadow offsetY="10.0">
                           <color>
                              <Color opacity="0.10000000149011612" />
                           </color>
                        </DropShadow>
                     </effect>
                     <children>
                        <StackPane fx:id="formContainer">
                           <children>
                              <VBox fx:id="registerForm" alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="20.0" visible="false" StackPane.alignment="TOP_LEFT">
                                 <children>
                                    <Label text="Tạo tài khoản mới">
                                       <font>
                                          <Font name="System Bold" size="28.0" />
                                       </font>
                                    </Label>
                                    <TextField promptText="Username" style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;" />
                                    <TextField promptText="Email" style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;" />
                                    <PasswordField promptText="Password" style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 12;" />
                                    <PasswordField promptText="Confirm password" style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;" />
                                    <Button mnemonicParsing="false" prefHeight="30.0" prefWidth="400.0" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" text="ĐĂNG KÝ" />
                                    <Hyperlink text="Đã có tài khoản? Đăng nhập" textFill="#6b7280" />
                                 </children>
                              </VBox>
                              
                              <VBox fx:id="loginForm" alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="20.0" StackPane.alignment="CENTER">
                                 <children>
                                    <Label text="Chào mừng trở lại" textFill="#1f2937">
                                       <font>
                                          <Font name="System Bold" size="28.0" />
                                       </font>
                                    </Label>
                                    <TextField fx:id="usernameField" promptText="Tên đăng nhập hoặc email" style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;" />
                                    <PasswordField fx:id="passwordField" promptText="Mật khẩu" style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-background-radius: 12; -fx-padding: 12;" />
                                    <Button mnemonicParsing="false" onAction="#handleLogin" prefHeight="30.0" prefWidth="400.0" style="-fx-background-color: #1E3A8A; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" text="ĐĂNG NHẬP">
                                       <cursor>
                                          <Cursor fx:constant="HAND" />
                                       </cursor>
                                    </Button>
                                    <Hyperlink text="Chưa có tài khoản? Đăng ký ngay" textFill="#6b7280" />
                                 </children>
                              </VBox>
                           </children>
                        </StackPane>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
         </children>
      </HBox>
   </children>
</StackPane>
