<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0" prefWidth="1200.0" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.shopcloud.superapp.controller.MainController">

    <!-- ====== THANH HEADER BAR TÙY CHỈNH (Custom Title Bar) ====== -->
    <top>
        <HBox fx:id="headerBar" alignment="CENTER_LEFT" prefHeight="40.0" spacing="10" style="-fx-background-color: #1E3A8A; -fx-padding: 0 16 0 16;">
            <children>
                <!-- Tiêu đề thương hiệu bên trái -->
                <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="☁ SHOP CLOUD SUPER APP — Workspace Portal" />

                <!-- Region đệm tự co giãn chiếm hết khoảng trống ở giữa -->
                <Region HBox.hgrow="ALWAYS" />

                <!-- Cụm tài khoản + Nút Đăng xuất ở góc phải, giữ margin an toàn 130px cách 3 nút điều khiển cửa sổ -->
                <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 0 130 0 0;">
                    <children>
                        <Label fx:id="lblAccountInfo" style="-fx-text-fill: #E2E8F0; -fx-font-weight: bold; -fx-font-size: 12px;" text="Tài khoản" />
                        <Button fx:id="btnLogoutTop" onAction="#handleLogout" style="-fx-background-color: #FEE2E2; -fx-text-fill: #DC2626; -fx-background-radius: 12; -fx-padding: 4 12 4 12; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;" text="Đăng xuất" />
                    </children>
                </HBox>

                <!-- Cụm 3 nút điều khiển cửa sổ -->
                <HBox alignment="CENTER_RIGHT" spacing="8">
                    <children>
                        <!-- Nút Thu nhỏ xuống Taskbar -->
                        <Button fx:id="btnMinimize" onAction="#handleMinimize" style="-fx-background-color: transparent; -fx-text-fill: #94A3B8; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="—" />
                        <!-- Nút Phóng to / Khôi phục kích thước -->
                        <Button fx:id="btnMaximize" onAction="#handleMaximizeRestore" style="-fx-background-color: transparent; -fx-text-fill: #94A3B8; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="☐" />
                        <!-- Nút Đóng cửa sổ -->
                        <Button fx:id="btnCloseWindow" onAction="#handleCloseWindow" style="-fx-background-color: transparent; -fx-text-fill: #F87171; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="✕" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefHeight="720.0" prefWidth="272.0" spacing="20" styleClass="sidebar">

            <padding>
                <Insets bottom="25" left="20" right="20" top="35" />
            </padding>

            <VBox alignment="CENTER" spacing="4" styleClass="brand-box">
                <Label styleClass="logo" text="☁ SHOP CLOUD" textFill="#1e3a8a">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font></Label>
                <Label styleClass="logo-subtitle" text="Workspace Portal">
               <font>
                  <Font size="14.0" />
               </font></Label>
            </VBox>

            <Button fx:id="btnBuyerSpace" maxWidth="Infinity" onAction="#loadBuyerSpace" style="-fx-background-color: #1E3A8A; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20 8 20; -fx-font-weight: bold;" styleClass="menu-button, menu-button-buyer" text="Không gian Người Mua">
                <effect>
                    <DropShadow color="#2563EB1A" offsetY="4" radius="15" />
                </effect>
            </Button>

            <!-- Kênh Người Bán — Nút chính + Sub-menu mở rộng -->
            <VBox spacing="6">
                <children>
                    <Button fx:id="btnSellerSpace" maxWidth="Infinity" onAction="#handleToggleSellerMenu" style="-fx-background-color: #1E3A8A; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20 8 20; -fx-font-weight: bold;" styleClass="menu-button, menu-button-seller" text="Kênh Người Bán">
                        <effect>
                            <DropShadow color="#0596691A" offsetY="4" radius="15" />
                        </effect>
                    </Button>
                    <!-- Sub-menu ẩn mặc định — hiển thị khi bấm nút chính -->
                    <VBox fx:id="sellerSubMenu" managed="false" spacing="4" style="-fx-padding: 0 0 0 12;" visible="false">
                        <children>
                            <Button fx:id="btnAddProduct" maxWidth="Infinity" onAction="#loadAddProductView" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-background-radius: 16; -fx-padding: 7 16 7 16; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;" text="Đăng bán sản phẩm" />
                            <Button fx:id="btnMyProducts" maxWidth="Infinity" onAction="#loadMyProductsView" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-background-radius: 16; -fx-padding: 7 16 7 16; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;" text="Sản phẩm của tôi" />
                            <Button fx:id="btnSellerReviews" maxWidth="Infinity" onAction="#loadSellerReviewView" style="-fx-background-color: #8B5CF6; -fx-text-fill: white; -fx-background-radius: 16; -fx-padding: 7 16 7 16; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;" text="Quản lý đánh giá" />
                        </children>
                    </VBox>
                </children>
            </VBox>

            <Button fx:id="btnAdminSpace" maxWidth="Infinity" onAction="#loadAdminSpace" style="-fx-background-color: #1E3A8A; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20 8 20; -fx-font-weight: bold;" styleClass="menu-button, menu-button-admin" text="Quản Trị Admin">
                <effect>
                    <DropShadow color="#1E3A8A33" offsetY="4" radius="15" />
                </effect>
            </Button>

            <!-- Region co giãn đẩy nút Đăng xuất xuống cuối Sidebar -->
            <Region VBox.vgrow="ALWAYS" />

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content" />
    </center>

</BorderPane>
