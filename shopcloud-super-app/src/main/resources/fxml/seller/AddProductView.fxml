<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!-- Màn hình Đăng bán sản phẩm mới — tách riêng khỏi SellerSpace cũ.
     ScrollPane đảm bảo nút "Đăng bán" luôn hiển thị khi resize/thu nhỏ cửa sổ. -->
<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            style="-fx-background-color: #F3F4F6; -fx-background: #F3F4F6;"
            stylesheets="@../style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.shopcloud.superapp.controller.seller.AddProductController">
    <content>
        <VBox alignment="TOP_CENTER" spacing="0" style="-fx-background-color: #F3F4F6;">
            <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>
            <children>
                <!-- Card chứa Form đăng bán -->
                <VBox maxWidth="650" alignment="TOP_LEFT" spacing="16"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E5E7EB; -fx-border-radius: 16; -fx-border-width: 1; -fx-padding: 30;">
                    <effect><DropShadow color="#0000000D" offsetY="4" radius="12" /></effect>
                    <children>
                        <!-- Tiêu đề -->
                        <Label text="Đăng bán sản phẩm mới" style="-fx-text-fill: #1E3A8A;">
                            <font><Font name="System Bold" size="22" /></font>
                        </Label>
                        <Label text="Điền đầy đủ thông tin sản phẩm để đăng lên ShopCloud Marketplace" style="-fx-text-fill: #6B7280; -fx-font-size: 13px;" />

                        <!-- Tên sản phẩm -->
                        <VBox spacing="6">
                            <children>
                                <Label text="Tên sản phẩm *" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #374151;" />
                                <TextField fx:id="productNameField" promptText="Nhập tên sản phẩm (ví dụ: Áo đấu CR7 World Cup 2026)" maxWidth="1.7976931348623157E308" />
                            </children>
                        </VBox>

                        <!-- Đơn giá & Số lượng — 2 cột ngang -->
                        <HBox spacing="16">
                            <children>
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Đơn giá (VNĐ) *" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #374151;" />
                                        <TextField fx:id="productPriceField" promptText="Nhập giá tiền" maxWidth="1.7976931348623157E308" />
                                    </children>
                                </VBox>
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Số lượng tồn kho *" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #374151;" />
                                        <TextField fx:id="productStockField" promptText="Nhập số lượng" maxWidth="1.7976931348623157E308" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- Mô tả chi tiết -->
                        <VBox spacing="6">
                            <children>
                                <Label text="Mô tả chi tiết" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #374151;" />
                                <TextArea fx:id="productDescriptionArea" promptText="Nhập mô tả chi tiết sản phẩm..." wrapText="true" prefRowCount="4" maxWidth="1.7976931348623157E308" />
                            </children>
                        </VBox>

                        <!-- Vùng tải ảnh sản phẩm -->
                        <VBox spacing="10">
                            <children>
                                <Label text="Ảnh sản phẩm" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #374151;" />
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <children>
                                        <!-- Khung xem trước ảnh 150x150 -->
                                        <VBox fx:id="imagePreviewContainer" alignment="CENTER" prefWidth="150" prefHeight="150"
                                              style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 12; -fx-background-radius: 12; -fx-border-width: 1.5; -fx-border-style: dashed;">
                                            <children>
                                                <ImageView fx:id="imgPreview" fitHeight="130" fitWidth="130" preserveRatio="true" />
                                                <Label fx:id="lblImagePlaceholder" text="Chưa có ảnh" style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px;" />
                                            </children>
                                        </VBox>
                                        <!-- Nút chọn ảnh & thông tin file -->
                                        <VBox spacing="8" alignment="CENTER_LEFT">
                                            <children>
                                                <Button fx:id="btnUploadImage" text="📁 Chọn ảnh từ máy tính"
                                                        onAction="#handleUploadImage"
                                                        style="-fx-background-color: #EFF6FF; -fx-text-fill: #2563EB; -fx-font-weight: bold; -fx-background-radius: 10; -fx-border-color: #BFDBFE; -fx-border-radius: 10; -fx-padding: 8 16 8 16; -fx-cursor: hand;" />
                                                <Label fx:id="lblImagePath" text="Hỗ trợ: PNG, JPG, JPEG" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px;" wrapText="true" maxWidth="250" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Nút Đăng bán — luôn hiển thị nhờ ScrollPane bọc ngoài -->
                        <Button fx:id="btnPublish" text="🚀 Đăng bán sản phẩm" mnemonicParsing="false"
                                onAction="#handlePublishProduct" maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 10; -fx-padding: 12 30 12 30; -fx-cursor: hand;">
                            <effect><DropShadow color="#10B98140" offsetY="4" radius="10" /></effect>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
