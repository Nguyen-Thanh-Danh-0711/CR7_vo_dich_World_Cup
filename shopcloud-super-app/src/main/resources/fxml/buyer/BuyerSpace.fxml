<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="12.0" style="-fx-padding: 24;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <BorderPane prefHeight="650.0" prefWidth="850.0">
      <top>
         <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <children>
               <TextField prefWidth="400.0" promptText="Tìm kiếm sản phẩm" />
               <Button alignment="CENTER" lineSpacing="10.0" mnemonicParsing="false" text="Tìm kiếm" />
            </children>
            <padding>
               <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
         </HBox>
      </top>
      <center>
         <ScrollPane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
           <content>
             <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="200.0" prefWidth="200.0">
                  <children>
                     <TilePane hgap="15.0" prefHeight="200.0" prefWidth="200.0" vgap="15.0">
                        <padding>
                           <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                        </padding>
                        <children>
                           <VBox prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0); -fx-padding: 10;">
                              <children>
                                 <ImageView fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />
                                 <Label text="Tên sản phẩm mẫu">
                                    <font>
                                       <Font name="System Bold" size="16.0" />
                                    </font>
                                 </Label>
                                 <Label style="-fx-text-fill: red;" text="99000đ">
                                    <font>
                                       <Font size="15.0" />
                                    </font></Label>
                                 <Button mnemonicParsing="false" prefWidth="200.0" style="-fx-background-color: #ee4d2d; -fx-text-fill: white;" text="Mua ngay" />
                              </children>
                           </VBox>
                        </children>
                     </TilePane>
                  </children>
               </AnchorPane>
           </content>
         </ScrollPane>
      </center>
   </BorderPane>
</VBox>
