<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.shopcloud.superapp.controller.MainController"
            prefHeight="640.0" prefWidth="1024.0">

    <left>
        <VBox spacing="8.0" style="-fx-padding: 12;">
            <Button fx:id="btnBuyerSpace" mnemonicParsing="false" onAction="#loadBuyerSpace"
                    text="Không gian Người Mua" maxWidth="Infinity"/>
            <Button fx:id="btnSellerSpace" mnemonicParsing="false" onAction="#loadSellerSpace"
                    text="Kênh Người Bán" maxWidth="Infinity"/>
            <Button fx:id="btnAdminSpace" mnemonicParsing="false" onAction="#loadAdminSpace"
                    text="Quản Trị Admin" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f5f5f5;"/>
    </center>

</BorderPane>
