<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!-- Màn hình Quản lý sản phẩm của tôi — tách riêng khỏi SellerSpace cũ.
     TableView hiển thị danh sách sản phẩm với cột Thao tác (Xem/Sửa/Xóa). -->
<VBox spacing="15" style="-fx-background-color: #F3F4F6;"
      stylesheets="@../style.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.shopcloud.superapp.controller.seller.MyProductsController">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
    <children>
        <!-- Card chứa header và TableView -->
        <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E5E7EB; -fx-border-radius: 16; -fx-border-width: 1; -fx-padding: 25;" VBox.vgrow="ALWAYS">
            <effect><DropShadow color="#0000000D" offsetY="4" radius="12" /></effect>
            <children>
                <!-- Tiêu đề và thống kê -->
                <Label text="Sản phẩm của tôi" style="-fx-text-fill: #1E3A8A;">
                    <font><Font name="System Bold" size="22" /></font>
                </Label>
                <Label fx:id="lblProductCount" text="Tổng: 0 sản phẩm" style="-fx-text-fill: #6B7280; -fx-font-size: 13px;" />

                <!-- Bảng danh sách sản phẩm -->
                <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colProductId" prefWidth="90" text="Mã SP" />
                        <TableColumn fx:id="colProductName" prefWidth="200" text="Tên sản phẩm" />
                        <TableColumn fx:id="colProductPrice" prefWidth="140" text="Đơn giá" />
                        <TableColumn fx:id="colProductStock" prefWidth="100" text="Tồn kho" />
                        <TableColumn fx:id="colActions" prefWidth="250" text="Thao tác" sortable="false" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
