<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #F9FAFB;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.shopcloud.superapp.controller.AdminReportController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>

   <!-- Header & Filter Bar -->
   <top>
      <VBox spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <!-- Title Bar -->
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <VBox spacing="4.0">
                     <children>
                        <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="TRUNG TÂM BÁO CÁO VI PHẠM &amp; CẢNH BÁO" />
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #6B7280;" text="Tiếp nhận và xử lý khiếu nại vi phạm tiêu chuẩn cộng đồng từ Người dùng." />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- Filter & Search Controls -->
            <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: white; -fx-padding: 14; -fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-radius: 10;">
               <effect>
                  <DropShadow blurType="GAUSSIAN" color="#0000000a" offsetY="2.0" radius="6.0" />
               </effect>
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Lọc trạng thái:" />
                  <ComboBox fx:id="statusFilterComboBox" prefWidth="160.0" style="-fx-background-radius: 20; -fx-border-color: #D1D5DB; -fx-border-radius: 20;" />

                  <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Tìm kiếm:" />
                  <TextField fx:id="searchField" prefWidth="250.0" promptText="Tìm theo Mã BC, Tên hoặc Lý do..." style="-fx-background-radius: 20; -fx-border-color: #D1D5DB; -fx-border-radius: 20;" />

                  <Region HBox.hgrow="ALWAYS" />

                  <!-- Count Badges -->
                  <HBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Label style="-fx-background-color: #FEF3C7; -fx-text-fill: #D97706; -fx-font-weight: bold; -fx-padding: 6 12; -fx-background-radius: 20;" text="Chờ xử lý" />
                        <Label fx:id="pendingCountLabel" style="-fx-font-weight: 900; -fx-font-size: 14px; -fx-text-fill: #D97706;" text="0" />
                     </children>
                  </HBox>
               </children>
            </HBox>
         </children>
         <VBox.margin>
            <Insets bottom="15.0" />
         </VBox.margin>
      </VBox>
   </top>

   <!-- Main Table Area -->
   <center>
      <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-padding: 12;" BorderPane.alignment="CENTER">
         <effect>
            <DropShadow blurType="GAUSSIAN" color="#0000000a" offsetY="2.0" radius="6.0" />
         </effect>
         <children>
            <TableView fx:id="reportTableView" style="-fx-background-radius: 8;" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colReportId" prefWidth="90.0" text="Mã Báo Cáo" />
                  <TableColumn fx:id="colTargetType" prefWidth="100.0" text="Loại Đối Tượng" />
                  <TableColumn fx:id="colTargetName" prefWidth="180.0" text="Tên Đối Tượng" />
                  <TableColumn fx:id="colReporter" prefWidth="130.0" text="Người Báo Cáo" />
                  <TableColumn fx:id="colReason" prefWidth="220.0" text="Lý Do Vi Phạm" />
                  <TableColumn fx:id="colEvidence" prefWidth="180.0" text="Bằng Chứng" />
                  <TableColumn fx:id="colCreatedAt" prefWidth="130.0" text="Thời Gian" />
                  <TableColumn fx:id="colStatus" prefWidth="110.0" text="Trạng Thái" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </center>

   <!-- Bottom Action Toolbar -->
   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: white; -fx-padding: 14 20; -fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-radius: 10;" BorderPane.alignment="CENTER">
         <effect>
            <DropShadow blurType="GAUSSIAN" color="#0000000a" offsetY="-2.0" radius="6.0" />
         </effect>
         <VBox.margin>
            <Insets top="15.0" />
         </VBox.margin>
         <children>
            <Label style="-fx-font-weight: bold; -fx-text-fill: #4B5563;" text="Thao tác đối với báo cáo chọn:" />

            <Button fx:id="btnReplyReport" mnemonicParsing="false" onAction="#handleReplyReport" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 20; -fx-cursor: hand;" text="Phản Hồi Báo Cáo" />

            <Button fx:id="btnSendWarning" mnemonicParsing="false" onAction="#handleSendWarning" style="-fx-background-color: #D97706; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 20; -fx-cursor: hand;" text="Gửi Cảnh Báo" />

            <Button fx:id="btnBanTarget" mnemonicParsing="false" onAction="#handleBanTarget" style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 20; -fx-cursor: hand;" text="Khóa Tài Khoản / Shop" />

            <Button fx:id="btnDeleteProduct" mnemonicParsing="false" onAction="#handleDeleteProduct" style="-fx-background-color: #991B1B; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 20; -fx-cursor: hand;" text="Xóa Sản Phẩm Vi Phạm" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
